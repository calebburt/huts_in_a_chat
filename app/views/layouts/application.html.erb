<!DOCTYPE html>
<html>
  <head>
    <title><%= (content_for(:title) || "Home") + " | Huts in a Chat" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">

    <% if current_user && Rails.env != "test" %>
      <%= tag.meta name: "vapid-public-key", content: Rails.application.credentials.vapid.public %>
    <% end %>

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <% if current_user && current_user.img_url.present? %>
      <style>
        body {
          background-image: url('<%= current_user.img_url %>')
        }
      </style>
    <% end %>
  </head>
  
  <body>
    <header class="titlebar">
      <img src="/icon.png" alt="Huts in a Chat Logo" class="vertical-align-middle padding-10">
      <h1 class="vertical-align-middle">Huts in a Chat</h1>
      <% if current_user %>
        <ul>
          <li><%= link_to "Chats", chats_path %></li>
          <li><%= link_to "Profile", user_path(current_user) %></li>
          <li><%= link_to "Users", users_path %></li>
          <li><%= link_to "DMs", dm_chats_path %></li>
          <li><%= link_to "Invite", auth_new_path %></li>
          <li><%= button_to "Logout", auth_logout_path, method: :post, form: { style: "display:inline" }, class: "link-button" %></li>
        </ul>
      <% end %>
    </header>
    <main>
      <% if notice || alert %>
        <div class="flash-toasts" role="region" aria-label="Notifications">
          <% if notice %>
            <div class="flash flash--notice" role="status" data-controller="flash">
              <svg class="flash__icon" viewBox="0 0 24 24" aria-hidden="true">
                <circle cx="12" cy="12" r="10" fill="currentColor" opacity="0.15"/>
                <path d="M7 12.5l3 3 7-7" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span class="flash__message"><%= notice %></span>
              <button type="button" class="flash__close" aria-label="Dismiss" data-action="flash#dismiss">&times;</button>
            </div>
          <% end %>
          <% if alert %>
            <div class="flash flash--alert" role="alert" data-controller="flash">
              <svg class="flash__icon" viewBox="0 0 24 24" aria-hidden="true">
                <circle cx="12" cy="12" r="10" fill="currentColor" opacity="0.15"/>
                <path d="M12 7v6" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"/>
                <circle cx="12" cy="16.5" r="1.2" fill="currentColor"/>
              </svg>
              <span class="flash__message"><%= alert %></span>
              <button type="button" class="flash__close" aria-label="Dismiss" data-action="flash#dismiss">&times;</button>
            </div>
          <% end %>
        </div>
      <% end %>
      <%= yield %>
    </main>
    <% if !session[:seen_6_0_release] && current_user %>
    <style>
      dialog {
        position: fixed;
        top: 50%;
        left: 50%;
        color: white;
        transform: translate(-50%, -50%);
        background-color: #45AC7077 !important;
        border: 1px solid #ddd5 !important;
      }
    </style>
    <dialog open class="section">
      <h1>Huts in a Chat 6.0 Released!</h1>
      <p>After months of developments, Huts in a Chat 6.0 is finally done! The changes have been gradual, and all features have been out for a week. However, as of today, some fixes have been done.</p>
    </dialog>
    <%= javascript_tag nonce: true do %>
      const dialog = document.querySelector("dialog");
      if (dialog) {
        setTimeout(() => dialog.close(), 10000);
      }
    <% end %>
    <% session[:seen_6_0_release] = true %>
    <% end %>
    <%= javascript_tag nonce: true do %>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          navigator.serviceWorker
            .register("/service-worker.js")
            .catch(err => console.error("SW registration failed:", err));
        });
      }
    <% end %>
    <% if current_user %>
    <%= javascript_tag nonce: true, type: "module" do %>
      const checkPermission = async () => {
        switch (Notification.permission) {
          case 'granted':
            console.log('Permission to receive notifications has been granted');
            break;
          case 'denied':
            console.log('Permission to receive notifications has been denied');
            break;
          default:
            const permission = await Notification.requestPermission();
            console.log(`Permission to receive notifications has been ${permission}`);
            break;
        }
      };
      checkPermission();

      const vapidPublicKey = document.querySelector(
        'meta[name="vapid-public-key"]',
      ).content;

      // Firefox/Safari require a Uint8Array applicationServerKey; only
      // Chrome accepts the raw URL-safe base64 string.
      const urlBase64ToUint8Array = (base64String) => {
        const padding = "=".repeat((4 - (base64String.length % 4)) % 4);
        const base64 = (base64String + padding).replace(/-/g, "+").replace(/_/g, "/");
        const raw = atob(base64);
        const out = new Uint8Array(raw.length);
        for (let i = 0; i < raw.length; ++i) out[i] = raw.charCodeAt(i);
        return out;
      };

      const subscribe = async () => {
        const registration = await navigator.serviceWorker.ready;

        let subscription = await registration.pushManager.getSubscription();

        if (!subscription) {
          try {
            subscription = await registration.pushManager.subscribe({
              userVisibleOnly: true,
              applicationServerKey: urlBase64ToUint8Array(vapidPublicKey),
            });
          } catch (err) {
            console.error('Web push subscription failed:', err);
            return null;
          }
        }

        return subscription;
      };

      const subscription = await subscribe();
      if (subscription) {
        const { post } = await import('@rails/request.js');

        const {
          endpoint,
          keys: { p256dh, auth },
        } = subscription.toJSON();

        const body = JSON.stringify({
          push_subscription: { endpoint, p256dh_key: p256dh, auth_key: auth },
        });

        post('/auth/push_subscriptions', { body, contentType: 'application/json' });
      }
    <% end %>
    <% end %>
  </body>
</html>
