<div class="chat-layout">
  <div id="messages_section" class="section messages-section">
    <% content_for :title, @chat.name %>

    <div class="chat-header"
    <% if @shown_as_moderator %>
      style="background-color: rgba(255, 128, 0, 0.4); padding: 5px; border-radius: 12px;"
    <% end %>
    >
      <h1 class="text-no-margin"><%= @chat.name %><% if @chat.announcements? %> 📢<% end %></h1>
      <% can_manage_chat = @chat.group_chat? || (@chat.announcements? && current_user.is_moderator?) %>
      <%= button_to "Destroy Chat", @chat, method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-danger" unless @chat.announcements? && !current_user.is_moderator? %>
      <%= button_to "Edit chat", edit_chat_path(@chat), method: :get, class: "btn btn-primary" if can_manage_chat %>
    </div>

    <div id="messages" class="section section-light messages-container"
         data-controller="auto-scroll infinite-scroll"
         data-infinite-scroll-url-value="<%= chat_messages_path(@chat) %>">
      <% if @has_more_messages %>
        <%= render "chats/messages_top_sentinel", before_id: @messages.first.id %>
      <% end %>
      <%= render @messages %>
    </div>

    <%= javascript_tag nonce: true do %>
      (() => {
        // Mirrors Rails's distance_of_time_in_words (include_seconds: false),
        // so the live label matches the server-rendered text exactly.
        const pluralize = (n, singular) => `${n} ${n === 1 ? singular : singular + "s"}`;
        const MIN_IN_YEAR = 525600;
        const MIN_IN_QUARTER_YEAR = MIN_IN_YEAR / 4;

        const timeAgoInWords = (date) => {
          const minutes = Math.round((Date.now() - date.getTime()) / 60000);
          if (minutes < 1)      return "less than a minute";
          if (minutes === 1)    return "1 minute";
          if (minutes <= 44)    return `${minutes} minutes`;
          if (minutes <= 89)    return "about 1 hour";
          if (minutes <= 1439)  return `about ${Math.round(minutes / 60)} hours`;
          if (minutes <= 2519)  return "1 day";
          if (minutes <= 43199) return `${Math.round(minutes / 1440)} days`;
          if (minutes <= 86399) return "about 1 month";
          if (minutes <= 525599) return `about ${Math.round(minutes / 43200)} months`;
          const years = Math.floor(minutes / MIN_IN_YEAR);
          const remainder = minutes % MIN_IN_YEAR;
          if (remainder < MIN_IN_QUARTER_YEAR)     return `about ${pluralize(years, "year")}`;
          if (remainder < MIN_IN_QUARTER_YEAR * 3) return `over ${pluralize(years, "year")}`;
          return `almost ${pluralize(years + 1, "year")}`;
        };

        const update = () => {
          document.querySelectorAll("time[data-live-time]").forEach((el) => {
            const dt = el.getAttribute("datetime");
            if (!dt) return;
            const next = timeAgoInWords(new Date(dt)) + " ago";
            if (el.textContent !== next) el.textContent = next;
          });
        };

        update();

        // Avoid stacking intervals if this view re-renders via Turbo navigation.
        if (window.__liveTimeInterval) clearInterval(window.__liveTimeInterval);
        window.__liveTimeInterval = setInterval(update, 30000);

        // Observe direct children of #messages only — NOT subtree — because our
        // own textContent writes to <time> nodes are childList mutations inside
        // the subtree and would re-trigger the observer, hanging the page.
        // Top-level childList is enough: appends, turbo_stream replaces of a
        // message dom_id, and removes all mutate #messages' direct children.
        const messages = document.getElementById("messages");
        if (messages) {
          new MutationObserver(update).observe(messages, { childList: true });
        }
      })();
    <% end %>

    <% if !@chat.announcements? || current_user.is_moderator? %>
      <%= render "messages/form" %>
    <% end %>
  </div>
  <%= turbo_stream_from [ @chat, current_user ] %>
  <div id="members" class="section members-section">
    <h2>Members</h2>
    <hr>
    <% @chat.users.each do |user| %>
      <p><%= image_tag user.avatar, style: "width: 1em; height: 1em; border-radius: 20%; margin-right: 10px; object-fit: cover; vertical-align: middle;" if user.avatar.attached? %><%= link_to user.name, user, class: "link-no-decoration" %></p>
    <% end %>
  </div>
</div>