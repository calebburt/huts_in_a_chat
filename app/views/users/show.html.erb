<div class="section" style="display: flex; flex-direction: column; gap: 10px; height: 100%; min-height: 0;">
  <%= content_for :title, @user.name %>

  <div style="display: flex; align-items: center; justify-content: space-between; gap: 10px;">
    <h1 style="margin: 0;"><%= @user.name %></h1>
    <% if session[:user_id] == @user.id %>
      <%= link_to "Edit", edit_user_path(@user), class: "btn btn-primary" %>
    <% end %>
  </div>

  <div style="overflow-y: auto; min-height: 0; height: calc(100% - 90px); display: flex; flex-direction: column; gap: 20px;">
    <h2>Bio</h2>
    <div class="section section-light"><%= render_markdown @user.bio %></div>

    <% if @user.img_url != "" %>
      <h2>Background Picture</h2>
      <img width="300" src="<%= @user.img_url %>" alt="Background picture">
    <% end %>
  </div>
</div>