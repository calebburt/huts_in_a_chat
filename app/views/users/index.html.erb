<div class="section users-layout">
    <%= content_for :title, "Users" %>
    <h1>Users</h1>

    <hr>
    <div id="users" class="users-list">
    <hr>
    <% @users.each do |user| %>
      <%= link_to user, class: "chat-link" do %>
        <h3><%= image_tag user.avatar, style: "width: 1em; height: 1em; border-radius: 20%; margin-right: 10px; object-fit: cover; vertical-align: middle;" if user.avatar.attached? %><%= user.name %></h3>
      <% end %>
      <hr>
    <% end %>
  </div>
</div>