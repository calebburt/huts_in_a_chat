<div class="section" style="
       display: flex;
       flex-direction: column;
       gap: 10px;
       height: 100%;
       min-height: 0;
     ">
    <%= content_for :title, "Users" %>
    <h1>Users</h1>

    <hr>
    <div id="users"
       style="
         overflow-y: auto;
         min-height: 0;
         height: calc(100% - 100px);
       ">
    <hr>
    <% @users.each do |user| %>
      <%= link_to user, style: "text-decoration: none; color: white;" do %>
        <h3><%= user.name %></h3>
      <% end %>
      <hr>
    <% end %>
  </div>
</div>