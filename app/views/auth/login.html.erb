<div class="section">
  <% content_for :title, "Login" %>
  <h1>Login</h1>

  <%= form_with url: auth_login_path, local: true, method: :post do |form| %>
    <div class="field">
      <%= form.label :email %>
      <%= form.email_field :email, required: true %>
    </div>

    <div class="field">
      <%= form.label :password %>
      <%= form.password_field :password, required: true %>
    </div>

    <div class="actions">
      <%= form.submit "Login", class: "btn-primary"%>
    </div>
  <% end %>
</div>