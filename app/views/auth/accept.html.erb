<div class="section">
  <% content_for :title, "Sign Up" %>
  <h1>Sign Up</h1>

  <%= form_with model: @token.user, url: auth_signup_path, local: true, method: :post do |form| %>
    <% if @token.user.errors.any? %>
      <div style="color: red">
        <h2><%= pluralize(@token.user.errors.count, "error") %> prohibited this chat from being saved:</h2>
        <ul>
          <% @token.user.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
    <div class="field">
      <%= form.label :name %>
      <%= form.text_field :name, required: true %>
    </div>

    <div class=field>
      <%= form.label :email %>
      <%= form.email_field :email, required: true %>
    </div>

    <div class="field">
      <%= form.label :password %>
      <%= form.password_field :password, required: true %>
    </div>
    

    <%= form.hidden_field :token, value: @token.token %>
    <!--<div class="field">
      <%= form.label :password_confirmation %>
      <%= form.password_field :password_confirmation, required: true %>
    </div>-->

    <div class="actions">
      <%= form.submit "Sign Up", class: "btn-primary"%>
    </div>
  <% end %>
</div>
